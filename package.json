{
  "name": "vtaiwan-hono",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vp run build:css && vp dev",
    "build:css": "vp exec tailwindcss -i ./src/styles/app.css -o ./public/styles.css --minify",
    "watch:css": "vp exec tailwindcss -i ./src/styles/app.css -o ./public/styles.css --watch",
    "build": "VITE_BUILD_ID=$(date +%s) sh -c 'vp run build:css && vp build -c vite.client.config.mts && vp build'",
    "preview": "vp preview",
    "deploy": "vp run build && vp exec wrangler deploy",
    "typecheck": "vp check --no-fmt --no-lint",
    "test": "vp test",
    "check": "vp check",
    "fmt": "vp fmt",
    "lemma:gen": "vp exec lsc gen --backend=dafny src/ssr/heads.ts && vp exec lsc gen --backend=dafny src/i18n/index.ts && vp exec lsc gen --backend=dafny src/router/routes.ts",
    "lemma:check": "vp exec lsc check --backend=dafny src/ssr/heads.ts && vp exec lsc check --backend=dafny src/i18n/index.ts && vp exec lsc check --backend=dafny src/router/routes.ts",
    "cf-typegen": "vp exec wrangler types"
  },
  "dependencies": {
    "@vue/server-renderer": "^3.5.32",
    "chinese-conv": "^3.2.2",
    "firebase": "^12.16.0",
    "hono": "^4.12.14",
    "jose": "^6.0.11",
    "lucide-vue-next": "^1.0.0",
    "marked": "^15.0.12",
    "vue": "^3.5.32",
    "vue-i18n": "^11.4.2",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.44.0",
    "@cloudflare/workers-types": "^5.20260719.1",
    "@tailwindcss/cli": "^4.3.0",
    "@types/node": "^22.10.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/compiler-sfc": "^3.5.32",
    "lemmascript": "^0.5.13",
    "oxfmt": "^0.59.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.6.0",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.4",
    "vite-plus": "0.2.4",
    "wrangler": "^4.83.0"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.4"
  },
  "devEngines": {
    "packageManager": {
      "name": "npm",
      "version": "12.0.1",
      "onFail": "download"
    }
  }
}
