{
  "name": "vtaiwan-hono",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "scripts": {
    "predev": "npm run build:css",
    "dev": "vite dev",
    "build:css": "tailwindcss -i ./src/styles/app.css -o ./public/styles.css --minify",
    "watch:css": "tailwindcss -i ./src/styles/app.css -o ./public/styles.css --watch",
    "build": "npm run build:css && vite build && vite build -c vite.client.config.mts",
    "preview": "vite preview",
    "deploy": "npm run build && wrangler deploy",
    "typecheck": "tsc --noEmit",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "@vue/server-renderer": "^3.5.32",
    "hono": "^4.12.14",
    "lucide-vue-next": "^1.0.0",
    "vue": "^3.5.32",
    "vue-i18n": "^11.4.2",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.32.3",
    "@tailwindcss/cli": "^4.3.0",
    "@types/node": "^22.10.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/compiler-sfc": "^3.5.32",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.6.0",
    "vite": "^7.0.0",
    "wrangler": "^4.83.0"
  }
}
